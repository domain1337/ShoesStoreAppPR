<Application x:Class="ShoesStoreApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/Windows/LoginWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="ModernBlueBrush" Color="#80D8FF"/>
        <SolidColorBrush x:Key="PlaceholderForeground" Color="#888888"/>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinHeight" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="border" BorderBrush="#B2EBF2" BorderThickness="1.5" Background="White" CornerRadius="15">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="5" ShadowDepth="0" Color="#B3E5FC" Opacity="0.4"/>
                                </Border.Effect>
                            </Border>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="12,2" VerticalAlignment="Center"/>
                            <TextBlock x:Name="placeholder" Text="{TemplateBinding Tag}" Foreground="Gray" 
                                   IsHitTestVisible="False" VerticalAlignment="Center" Margin="15,0,0,0" 
                                   Visibility="Collapsed" FontStyle="Italic"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#80D8FF"/>
                                <Setter TargetName="placeholder" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinHeight" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Grid>
                            <Border x:Name="border" BorderBrush="#B2EBF2" BorderThickness="1.5" Background="White" CornerRadius="15">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="5" ShadowDepth="0" Color="#B3E5FC" Opacity="0.4"/>
                                </Border.Effect>
                            </Border>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="12,2" VerticalAlignment="Center"/>

                            <TextBlock x:Name="placeholder" Text="{TemplateBinding Tag}" Foreground="Gray" 
                                   IsHitTestVisible="False" VerticalAlignment="Center" Margin="15,0,0,0" 
                                   Visibility="Visible" FontStyle="Italic"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#80D8FF"/>
                                <Setter TargetName="placeholder" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#00FA9A"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                        CornerRadius="15" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00C781"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="gd" Background="Transparent" SnapsToDevicePixels="true" Margin="2,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="gd" Property="Background" Value="#E0F7FA"/>
                                <Setter TargetName="gd" Property="CornerRadius" Value="5"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="gd" Property="Background" Value="#80D8FF"/>
                                <Setter TargetName="gd" Property="CornerRadius" Value="5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" 
                            BorderBrush="#B2EBF2" 
                            BorderThickness="1.5" 
                            Background="White" 
                            CornerRadius="15">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="5" ShadowDepth="0" Color="#B3E5FC" Opacity="0.4"/>
                                </Border.Effect>
                            </Border>

                            <Grid Margin="12,0,30,0">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" 
                                          IsHitTestVisible="False" 
                                          Content="{TemplateBinding SelectionBoxItem}" 
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                            </Grid>
                            <ToggleButton Grid.Column="0" Margin="0" Background="Transparent" BorderThickness="0"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid HorizontalAlignment="Right" Width="30" Background="Transparent">
                                            <Path x:Name="Arrow" Data="M0,0 L4,4 L8,0 Z" Fill="#80D8FF" 
                                          HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Width="8"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" 
                           Placement="Bottom" PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder" Background="White" BorderBrush="#B2EBF2" BorderThickness="1" 
                                CornerRadius="10" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="true">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#80D8FF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#80D8FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>