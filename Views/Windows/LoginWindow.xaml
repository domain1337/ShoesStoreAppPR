<Window x:Class="ShoesStoreApp.Views.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ShoesStoreApp.ViewModels.Base"
        Icon="/Assets/Images/logo2.png" 
        Title="ООО «Обувь» - Вход" Height="487" Width="400"
        WindowStartupLocation="CenterScreen"
        FontFamily="Times New Roman" Background="#FFFFFF">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Grid>
        <StackPanel Margin="20">
            <Border Background="#7FFF00" CornerRadius="10" Padding="10" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Assets/Images/logo.png" Height="50" Stretch="Uniform"/>
                    <TextBlock Text="ООО «Обувь»" FontSize="24" FontWeight="Bold" 
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Email:"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>

            <TextBlock Text="Пароль:"/>
            <PasswordBox x:Name="PassBox" Margin="0,5,0,20"/>

            <Button Content="ВОЙТИ" 
                    Command="{Binding LoginCommand}" 
                    CommandParameter="{Binding ElementName=PassBox}"
                    Background="#00FA9A" Height="40" FontWeight="Bold"/>

            <Button Content="Создать аккаунт" Command="{Binding RegisterCommand}" 
                    Background="Transparent" BorderThickness="0" Foreground="Gray"/>

            <Separator Margin="0,20"/>

            <Button Content="Войти как гость" Command="{Binding GuestCommand}" 
                    Background="#7FFF00" Height="35"/>
        </StackPanel>
    </Grid>
</Window>