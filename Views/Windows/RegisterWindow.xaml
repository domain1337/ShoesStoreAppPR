<Window x:Class="ShoesStoreApp.Views.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ShoesStoreApp.ViewModels.Base"
        Icon="/Assets/Images/logo.png" 
        Title="ООО «Обувь»  Регистрация" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" Background="#FFFFFF" FontFamily="Times New Roman">

    <Window.DataContext>
        <vm:RegisterViewModel/>
    </Window.DataContext>

    <Grid Margin="0,0,0,61">
        <Grid.RowDefinitions>
            <RowDefinition Height="423*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="20,20,20,95">
            <Border Background="#7FFF00" CornerRadius="10" Padding="10" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Assets/Images/logo.png" Height="50" Stretch="Uniform"/>
                    <TextBlock Text="Регистрация" FontSize="22" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Email" Margin="10,0,0,0" FontSize="14" Foreground="Gray"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
            Tag="Введите вашу почту..."/>

            <TextBlock Text="Пароль" Margin="10,0,0,0" FontSize="14" Foreground="Gray"/>
            <PasswordBox x:Name="RegPassBox" 
             Tag="Придумайте пароль"/>

            <Button Content="ЗАРЕГИСТРИРОВАТЬСЯ" 
                    Command="{Binding RegisterCommand}" 
                    CommandParameter="{Binding ElementName=RegPassBox}"
                    Background="#00FA9A" Height="45" FontWeight="Bold"/>

            <Button Content="Назад ко входу" 
                    Command="{Binding BackCommand}" 
                    Background="Transparent" BorderThickness="0" Margin="0,10,0,0" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</Window>