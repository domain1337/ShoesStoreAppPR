<Window x:Class="ShoesStoreApp.Views.Windows.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/Images/logo.png" 
        Title="Редактирование товара" Height="599" Width="400"
        WindowStartupLocation="CenterScreen" FontFamily="Times New Roman">
    <Grid Background="#FFFFFF" Margin="0,0,0,-27">
        <StackPanel Margin="20">
            <TextBlock Text="Название товара:" Margin="0,5"/>
            <TextBox Text="{Binding CurrentProduct.Title}" Margin="0,0,0,10"/>

            <TextBlock Text="Описание:" Margin="0,5"/>
            <TextBox Text="{Binding CurrentProduct.Description}" Height="60" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <TextBlock Text="Артикул:" Margin="0,5"/>
            <TextBox Text="{Binding CurrentProduct.Article}" Margin="0,0,0,10"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Цена:"/>
                    <TextBox Text="{Binding CurrentProduct.Price}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Скидка (%):"/>
                    <TextBox Text="{Binding CurrentProduct.Discount}"/>
                </StackPanel>
                <StackPanel Margin="0,66,0,-60">
                    <TextBlock Text="Фото товара:" Height="13"/>
                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding CurrentProduct.ImagePath}" IsReadOnly="True" VerticalContentAlignment="Center" RenderTransformOrigin="0.473,2.403" Margin="5,-8,5,10"/>
                        <Button Grid.Column="1" Content="ОБЗОР" Command="{Binding SelectImageCommand}" Width="60" Margin="5,-8,0,10"/>
                    </Grid>
                    <Image Source="{Binding CurrentProduct.ImagePath}" Height="100" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,5"/>
                </StackPanel>
            </Grid>

            <Button Content="СОХРАНИТЬ" Command="{Binding SaveCommand}" 
                    Background="#00FA9A" Height="40" Margin="0,30,0,0" FontWeight="Bold"/>
            <Button Content="ОТМЕНА" Click="Cancel_Click" 
                    Background="#7FFF00" Height="30" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>