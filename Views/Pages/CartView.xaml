<UserControl x:Class="ShoesStoreApp.Views.Pages.CartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Times New Roman">
    <Grid Background="White">
        <DockPanel Margin="20">
            <TextBlock DockPanel.Dock="Top" Text="КОРЗИНА ТОВАРОВ" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <Border DockPanel.Dock="Bottom" Background="#7FFF00" CornerRadius="10" Padding="15" Margin="0,15,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="ИТОГО:" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalPrice, StringFormat={}{0:N0} ₽}" FontSize="22" Foreground="Red" FontWeight="Bold" Margin="10,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ComboBox ItemsSource="{Binding PickupPoints}" 
                                  SelectedItem="{Binding SelectedPickupPoint}"
                                  DisplayMemberPath="FullAddress"
                                  Width="300" Height="35" Margin="0,0,15,0" 
                                  VerticalContentAlignment="Center"/>

                        <Button Content="ОФОРМИТЬ ЗАКАЗ" Width="180" Height="40" Background="#00FA9A" 
                                FontWeight="Bold" Command="{Binding CheckoutCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
            <DataGrid ItemsSource="{Binding CartItems}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Фото" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding FullImagePath}" Height="40"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding FinalPrice, StringFormat={}{0} ₽}" Width="100"/>
                    <DataGridTemplateColumn Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Удалить" Background="LightCoral" 
                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</UserControl>