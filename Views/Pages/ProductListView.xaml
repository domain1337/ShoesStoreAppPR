<UserControl x:Class="ShoesStoreApp.Views.Pages.ProductListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:ShoesStoreApp.Infrastructure"
             FontFamily="Times New Roman">

    <UserControl.Resources>
        <infra:DiscountColorConverter x:Key="DiscountConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="#FFFFFF">
        <ListBox ItemsSource="{Binding ProductsView}" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                 BorderThickness="0">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="1" Margin="10" Width="260" CornerRadius="8"
                            Background="{Binding Discount, Converter={StaticResource DiscountConverter}}">
                        <StackPanel Margin="15">
                            <Image Source="{Binding FullImagePath}" Height="140" Stretch="Uniform" Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" 
                                       HorizontalAlignment="Center" TextAlignment="Center" Height="45" TextWrapping="Wrap"/>

                            <TextBlock Text="{Binding Category}" FontSize="11" Foreground="#555" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding QuantityInStock, StringFormat='На складе: {0} шт.'}" 
                                       FontSize="12" HorizontalAlignment="Center" Margin="0,5"/>

                            <Separator Margin="0,8"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Price, StringFormat={}{0} ₽}" TextDecorations="Strikethrough" 
                                           Margin="0,0,10,0" Foreground="Gray" FontSize="13"
                                           Visibility="{Binding Discount, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding FinalPrice, StringFormat={}{0:N0} ₽}" 
                                           FontWeight="Bold" FontSize="18" Foreground="Red"/>
                            </StackPanel>

                            <TextBlock Text="{Binding Discount, StringFormat='Скидка: {0}%'}" 
                                       HorizontalAlignment="Right" Foreground="Blue" FontWeight="Bold" FontSize="12"/>
                            <Button Content="В КОРЗИНУ" 
                                    Background="#00FA9A" Height="40" Margin="0,15,0,0" FontWeight="Bold"
                                    Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>