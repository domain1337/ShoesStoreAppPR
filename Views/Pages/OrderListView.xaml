<UserControl x:Class="ShoesStoreApp.Views.Pages.OrderListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Times New Roman">

    <DockPanel Background="#FFFFFF">
        <Button Content="← НАЗАД К ТОВАРАМ" 
                DockPanel.Dock="Top"
                HorizontalAlignment="Left"
                Width="180" Height="35"
                Margin="15,10,0,0"
                Background="#7FFF00" 
                FontWeight="Bold"
                BorderThickness="1"
                Command="{Binding DataContext.ShowProductsCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>

        <TextBlock DockPanel.Dock="Top" 
                   Text="СПИСОК ЗАКАЗОВ" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Margin="10" 
                   HorizontalAlignment="Center"/>
        <DataGrid ItemsSource="{Binding Orders}" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  Margin="15"
                  Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="Auto"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding CustomerEmail}" Width="*"/>
                <DataGridTextColumn Header="Состав" Binding="{Binding OrderContent}" Width="2*"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice, StringFormat=\{0\} ₽}" Width="Auto"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>